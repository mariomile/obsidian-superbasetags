{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "target": "ES2021",
    "moduleResolution": "node",
    "allowJs": true,
    "noImplicitAny": true,
    "isolatedModules": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "strict": true,
    "noImplicitReturns": true,
    "lib": ["ES2021", "DOM"]
  },
  "include": ["src/**/*.ts"]
}
