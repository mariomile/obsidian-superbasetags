{
  "name": "obsidian-superbasetags",
  "version": "0.3.1",
  "packageManager": "pnpm@10.17.1",
  "description": "Tana-style supertags for Obsidian, built on #type/* tags and Bases.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "pnpm typecheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "bases",
    "supertags",
    "tana"
  ],
  "author": "Mario Miletta",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
